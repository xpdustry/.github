{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "labels": ["dependencies"],
  "semanticCommitType": "build",
  "commitMessagePrefix": "chore(deps): ",
  "packageRules": [
    {
      "matchDatasources": ["maven"],
      "registryUrls": ["https://maven.xpdustry.com/releases", "https://maven.xpdustry.com/snapshots"],
      "matchPackagePrefixes": ["com.xpdustry", "fr.xpdustry"]
    },
    {
      "matchDatasources": ["maven"],
      "registryUrls": ["https://maven.xpdustry.com/mindustry"],
      "matchPackagePrefixes": ["com.github.Anuken"]
    },
    {
      "matchDatasources": ["maven"],
      "registryUrls": ["https://maven.google.com/"],
      "matchPackagePrefixes": ["com.android.tools"]
    },
    {
      "groupName": "build systems",
      "matchManagers": ["github-actions", "gradle-wrapper"]
    },
    {
      "groupName": "build systems",
      "matchDepTypes": ["plugin"]
    },
    {
      "groupName": "build systems",
      "matchFileNames": ["build-logic/*", "buildSrc/*"]
    },
    {
      "groupName": "database drivers",
      "matchPackagePrefixes": [
        "org.xerial:sqlite-jdbc",
        "com.h2database:h2",
        "org.postgresql:postgresql",
        "org.mariadb.jdbc:mariadb-java-client",
        "com.mysql:mysql-connector-j"
      ]
    },
    {
      "groupName": "nohorny monorepo",
      "matchPackagePrefixes": ["com.xpdustry:nohorny"]
    }
  ],
  "pinDigest": {
    "schedule": ["at any time"]
  }
}
